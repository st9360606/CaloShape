<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 0ms 動畫 -->
    <style name="NoActivityAnim">
        <item name="android:activityOpenEnterAnimation">@anim/none</item>
        <item name="android:activityOpenExitAnimation">@anim/none</item>
        <item name="android:activityCloseEnterAnimation">@anim/none</item>
        <item name="android:activityCloseExitAnimation">@anim/none</item>
    </style>

    <!-- App 主題：Material 3、固定淺色、全白背景 -->
    <style name="Theme.CaloShape" parent="Theme.Material3.Light.NoActionBar">
        <!-- 停用自動深色 -->
        <item name="android:forceDarkAllowed">false</item>

        <!-- App 尚未繪製前的底色 -->
        <item name="android:windowBackground">@color/app_background</item>

        <!-- 系統列顏色 -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/app_background</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>

    <!-- Android 12+ 系統 Splash（只放無文字圖） -->
    <style name="Theme.CaloShape.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_bg</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_focus_spoon_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.CaloShape</item>
    </style>

    <style name="Theme.Transparent" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
    </style>

</resources>
