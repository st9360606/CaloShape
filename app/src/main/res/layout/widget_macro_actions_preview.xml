<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_macro_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <LinearLayout
        android:id="@+id/widget_macro_card"
        android:layout_width="match_parent"
        android:layout_height="175dp"
        android:layout_gravity="center"
        android:background="@drawable/widget_card_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingTop="6dp"
        android:paddingEnd="14dp"
        android:paddingBottom="6dp">

    <FrameLayout
        android:layout_width="114dp"
        android:layout_height="114dp">

        <ImageView
            android:id="@+id/widget_macro_calories_ring"
            android:layout_width="114dp"
            android:layout_height="114dp"
            android:src="@drawable/widget_preview_macro_calories_ring"
            android:contentDescription="@null" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingStart="10dp"
            android:paddingEnd="10dp">

            <TextView
                android:id="@+id/widget_macro_calories_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="sans-serif"
                android:textStyle="bold"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="@string/widget_preview_goal_kcal"
                android:textColor="#FF111114"
                android:textSize="26sp" />

            <TextView
                android:id="@+id/widget_macro_calories_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:ellipsize="end"
                android:fontFamily="sans-serif-medium"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="@string/widget_calories_left"
                android:textColor="#FF8D9198"
                android:textSize="12sp" />
        </LinearLayout>
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="34dp"
            android:baselineAligned="false"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <FrameLayout
                android:layout_width="34dp"
                android:layout_height="34dp">

                <ImageView
                    android:id="@+id/widget_protein_ring"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:src="@drawable/widget_preview_protein_ring"
                    android:contentDescription="@null" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:background="@drawable/widget_circle_protein_bg"
                    android:contentDescription="@null"
                    android:padding="3dp"
                    android:src="@drawable/ic_widget_protein" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/widget_protein_value"
                    android:layout_width="56dp"
                    android:layout_height="19dp"
                    android:fontFamily="sans-serif"
                    android:gravity="start|center_vertical"
                    android:includeFontPadding="false"
                    android:text="@string/widget_preview_protein"
                    android:textColor="#FF111114"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/widget_protein_label"
                    android:layout_width="match_parent"
                    android:layout_height="13dp"
                    android:layout_marginTop="1dp"
                    android:ellipsize="end"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="start|center_vertical"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:text="@string/widget_protein_left"
                    android:textColor="#FF2F3136"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="34dp"
            android:layout_marginTop="14dp"
            android:baselineAligned="false"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <FrameLayout
                android:layout_width="34dp"
                android:layout_height="34dp">

                <ImageView
                    android:id="@+id/widget_carbs_ring"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:src="@drawable/widget_preview_carbs_ring"
                    android:contentDescription="@null" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:background="@drawable/widget_circle_carbs_bg"
                    android:contentDescription="@null"
                    android:padding="3dp"
                    android:src="@drawable/ic_widget_carbs" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/widget_carbs_value"
                    android:layout_width="56dp"
                    android:layout_height="19dp"
                    android:fontFamily="sans-serif"
                    android:gravity="start|center_vertical"
                    android:includeFontPadding="false"
                    android:text="@string/widget_preview_carbs"
                    android:textColor="#FF111114"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/widget_carbs_label"
                    android:layout_width="match_parent"
                    android:layout_height="13dp"
                    android:layout_marginTop="1dp"
                    android:ellipsize="end"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="start|center_vertical"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:text="@string/widget_carbs_left"
                    android:textColor="#FF2F3136"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="34dp"
            android:layout_marginTop="14dp"
            android:baselineAligned="false"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <FrameLayout
                android:layout_width="34dp"
                android:layout_height="34dp">

                <ImageView
                    android:id="@+id/widget_fats_ring"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:src="@drawable/widget_preview_fats_ring"
                    android:contentDescription="@null" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:background="@drawable/widget_circle_fats_bg"
                    android:contentDescription="@null"
                    android:padding="3dp"
                    android:src="@drawable/ic_widget_fats" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/widget_fats_value"
                    android:layout_width="56dp"
                    android:layout_height="19dp"
                    android:fontFamily="sans-serif"
                    android:gravity="start|center_vertical"
                    android:includeFontPadding="false"
                    android:text="@string/widget_preview_fats"
                    android:textColor="#FF111114"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/widget_fats_label"
                    android:layout_width="match_parent"
                    android:layout_height="13dp"
                    android:layout_marginTop="1dp"
                    android:ellipsize="end"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="start|center_vertical"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:text="@string/widget_fats_left"
                    android:textColor="#FF2F3136"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:layout_width="3dp"
        android:layout_height="1dp"
        android:text="" />

    <TextView
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="@drawable/widget_divider_bg" />

    <TextView
        android:layout_width="7dp"
        android:layout_height="1dp"
        android:text="" />

    <LinearLayout
        android:layout_width="92dp"
        android:layout_height="match_parent"
        android:gravity="center_vertical|end"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/widget_scan_food_tile"
            android:layout_width="85dp"
            android:layout_height="70dp"
            android:background="@drawable/widget_action_light_bg"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="5dp">

            <FrameLayout
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="@drawable/widget_circle_gray_bg">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_widget_scan" />
            </FrameLayout>

            <TextView
                android:id="@+id/widget_scan_food_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:ellipsize="end"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="@string/widget_scan_food"
                android:textColor="#FF2F3136"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/widget_barcode_tile"
            android:layout_width="85dp"
            android:layout_height="70dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/widget_action_light_bg"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="5dp">

            <FrameLayout
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="@drawable/widget_circle_gray_bg">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_widget_barcode" />
            </FrameLayout>

            <TextView
                android:id="@+id/widget_barcode_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:ellipsize="end"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="@string/widget_barcode"
                android:textColor="#FF2F3136"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
</FrameLayout>
